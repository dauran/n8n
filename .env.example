# ============================================================
# n8n — Configuration
# Copy this file to `.env` then replace the values.
# ============================================================

# n8n image version (e.g. latest, 1.75.2). Pin in production.
N8N_VERSION=latest

# -------- PostgreSQL --------
POSTGRES_DB=n8n
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me_with_openssl_rand_hex_24

# Application (non-root) user used by n8n
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=replace_me_with_openssl_rand_hex_24

# -------- n8n --------
# Credentials encryption key (32-byte hex).
# Generate with: openssl rand -hex 32
# ⚠️ Never change after the first run, or stored credentials become unreadable.
N8N_ENCRYPTION_KEY=replace_me_with_openssl_rand_hex_32

# Public host/port/protocol (used for webhooks and the UI)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Timezone applied to scheduled workflows
GENERIC_TIMEZONE=Europe/Paris

# -------- Automatic backups --------
# Cron expression for the `backup` sidecar service.
# Examples: "0 */6 * * *" (every 6h), "0 2 * * *" (daily at 02:00), "*/15 * * * *" (every 15min)
# Set empty to disable automatic backups.
BACKUP_CRON="0 */6 * * *"
